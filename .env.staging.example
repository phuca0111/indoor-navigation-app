# Copy to .env.staging outside source control. Values below are placeholders.
HTTP_PORT=8080
PUBLIC_BASE_URL=https://staging.example.invalid
NODE_ENV=production
DEPLOY_ENV=staging

MONGO_INITDB_ROOT_USERNAME=staging_root
MONGO_INITDB_ROOT_PASSWORD=<generate-32-plus-random-characters>
MONGO_URI=mongodb://staging_root:<url-encoded-password>@mongo:27017/indoor_nav_staging?authSource=admin&replicaSet=rs0

REDIS_PASSWORD=<generate-32-plus-random-characters>
REDIS_URL=redis://:<url-encoded-password>@redis:6379/0

MINIO_ROOT_USER=<generate-random-access-key>
MINIO_ROOT_PASSWORD=<generate-32-plus-random-characters>
MINIO_ACCESS_KEY=<same-as-root-user-or-scoped-service-user>
MINIO_SECRET_KEY=<same-as-root-password-or-scoped-service-secret>
MINIO_BUCKET=indoor-nav-staging
MINIO_PUBLIC_URL=/storage
MINIO_SIGNED_URL_TTL_SECONDS=3600

JWT_SECRET=<generate-at-least-48-random-characters>
PAYMENT_TOKEN_SECRET=<generate-at-least-48-random-characters>
OAUTH_STATE_SECRET=<generate-at-least-48-random-characters>
IDENTITY_CHALLENGE_SECRET=<generate-at-least-48-random-characters>
METRICS_TOKEN=<generate-at-least-32-random-characters>

AUTH_RESET_TOKEN_IN_RESPONSE=false
MOCK_PAYMENT_ENABLED=false
PUBLISH_REQUIRE_TRANSACTION=true
DRAFT_REQUIRE_LOCK=true
DRAFT_REQUIRE_EXPECTED_VERSION=true
PUBLISH_REQUIRE_LOCK=true
STORAGE_BACKEND=minio
STORAGE_MAX_BYTES=10485760
HTTP_BODY_LIMIT=1mb

# Backup — passphrase must come from a secret manager/file in real staging.
BACKUP_ENVIRONMENT=staging
BACKUP_OUTPUT_DIR=/backups
BACKUP_ENCRYPTION_PASSPHRASE=<generate-at-least-32-random-characters>
BACKUP_RETENTION_DAYS=14
BACKUP_MONGO_DATABASE=indoor_nav_staging
BACKUP_MINIO_ALIAS=staging
BACKUP_MINIO_SOURCE=staging/indoor-nav-staging
RESTORE_NAMESPACE_ALLOWLIST=indoor_nav_staging,indoor_nav_test

# Optional alert adapter provider; HTTPS only in production mode.
# ALERT_PROVIDER_WEBHOOK_URL=https://alerts-provider.example.invalid/webhook
