{
  "grid": { "size": 40, "visible": true },
  "snap": {
    "tolerancePx": 12,
    "modes": {
      "grid": true,
      "endpoint": true,
      "midpoint": true,
      "intersection": true,
      "perpendicular": true
    }
  },
  "zoom": { "min": 0.1, "max": 5, "step": 0.1 },
  "autosave": { "intervalMs": 30000 },
  "units": { "display": "meters", "metersPerGrid": 0.5 }
}
