PORT=5000
MONGO_URI=mongodb://localhost:27017/HeThongBanDoTotNghiep
JWT_SECRET=change_this_to_a_long_random_secret
# Access token TTL — đồ án mặc định 7 ngày. Production: 15m (xem WorldFlow Phase 7).
JWT_ACCESS_EXPIRES_IN=7d

# Phase 7 — quên mật khẩu: trả resetToken trong JSON khi sandbox (chưa SMTP / gửi mail fail).
# Production: NODE_ENV=production → không bao giờ trả token JSON.
AUTH_RESET_TOKEN_IN_RESPONSE=true
# AUTH_RESET_TOKEN_TTL_MS=3600000

# URL public của backend (VNPay return + link trong email reset MK)
PUBLIC_BASE_URL=http://localhost:5000

# SMTP — quên mật khẩu (Gmail: bật 2FA → App Password). Để trống = sandbox (token trên trang).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=xxxx_app_password_xxxx
# SMTP_FROM="Indoor Nav <your@gmail.com>"

# Secret ký token thanh toán (>= 32 ký tự). Nên khác JWT_SECRET trên production.
PAYMENT_TOKEN_SECRET=change_this_payment_secret_min_32_chars

# Mock thanh toán: development = bật mặc định (khi chưa có VNPay)
# production = TẮT mặc định — chỉ bật nếu MOCK_PAYMENT_ENABLED=true (không khuyến nghị)
MOCK_PAYMENT_ENABLED=true
NODE_ENV=development

# Billing scheduler — kiểm tra grace/hết hạn (ms), mặc định 1 giờ
BILLING_SCHEDULER_MS=3600000

# Phase 8 — publish safety / floor lock / expiry mail / Google OAuth
PUBLISH_PERMIT_REQUIRED=false
# Chỉ dùng trong test: FORCE_PUBLISH_RATE_LIMIT=true (xem npm run test:phase8 TC-8.10)
FLOOR_EDIT_LOCK_TTL_SEC=120
# Development giữ tương thích client cũ; production mặc định strict nếu các biến này để trống.
DRAFT_REQUIRE_LOCK=false
DRAFT_REQUIRE_EXPECTED_VERSION=false
PUBLISH_REQUIRE_LOCK=false
# Production mặc định true ngay cả khi bỏ trống; cần Mongo replica set.
PUBLISH_REQUIRE_TRANSACTION=false
MAP_LIFECYCLE_TRANSACTIONS_ENABLED=false
PUBLISH_JOB_LEASE_MS=300000
# bullmq|memory|redis-list (redis-list chỉ legacy rollout)
PUBLISH_QUEUE=memory
FLOOR_LOCK_BACKEND=memory
PUBLISH_WORKER_IN_PROCESS=false
PUBLISH_QUEUE_ATTEMPTS=5
PUBLISH_QUEUE_BACKOFF_MS=1000
MAP_LIFECYCLE_INTERVAL_MS=3600000
BILLING_EXPIRY_REMIND_DAYS=3
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Nên đặt secret riêng ở production; fallback JWT_SECRET để tương thích.
OAUTH_STATE_SECRET=change_this_oauth_state_secret
OAUTH_STATE_TTL_SECONDS=600

# Identity migration/rollout — legacy user không bị ép verify nếu chưa đặt cutoff.
ALLOW_LEGACY_PLAINTEXT_PASSWORD=false
REFRESH_TOKEN_TTL_DAYS=7
IDENTITY_CHALLENGE_SECRET=change_this_identity_challenge_secret
IDENTITY_CHALLENGE_TTL_SECONDS=600
IDENTITY_CHALLENGE_MAX_ATTEMPTS=5
IDENTITY_CHALLENGE_RATE_PER_MINUTE=3
# Wave membership: legacy -> prefer-member -> member, chỉ chuyển "member" sau verify backfill.
IDENTITY_MEMBERSHIP_READ_SOURCE=legacy
IDENTITY_MEMBERSHIP_DUAL_WRITE=true
# Chỉ đặt true sau `npm run verify:organization-members` trả exit code 0.
IDENTITY_MEMBERSHIP_BACKFILL_VERIFIED=false
# Production bắt buộc transaction; test/dev standalone có thể tắt rõ ràng.
IDENTITY_TRANSACTIONS_ENABLED=true
# Alias cũ trong thời gian rollout, bỏ sau khi tất cả môi trường dùng READ_SOURCE.
IDENTITY_MEMBER_DUAL_READ=true
EMAIL_VERIFICATION_REQUIRED=false
# EMAIL_VERIFICATION_ENFORCE_AFTER=2026-08-01T00:00:00.000Z

# Script migration chỉ đọc biến riêng và mặc định dry-run; database phải có test/staging/migration/sandbox trong tên.
# TEST_MONGO_URI=mongodb://localhost:27017/indoor_nav_test
# MIGRATION_MONGO_URI=mongodb://localhost:27017/indoor_nav_migration

# Finance v2: mặc định legacy read; dual-write/read v2 chỉ bật sau backfill + verify.
FINANCE_LEDGER_DUAL_WRITE_V2=false
FINANCE_LEDGER_READ_V2=false
FINANCE_LEDGER_SHADOW_COMPARE=true
MIGRATION_BATCH_SIZE=200

# VNPay (production) — khi đã cấu hình đủ, hệ thống tự dùng VNPay thay Mock
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/webhooks/vnpay/return
VNPAY_API_URL=
VNPAY_REFUND_ENABLED=false

# Content platform storage: local | minio | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:5000
STORAGE_MAX_BYTES=5242880
STORAGE_QUOTA_BYTES=524288000
STORAGE_RETENTION_DAYS=30
STORAGE_INTENT_TTL_SECONDS=300
CMS_MEDIA_RATE_LIMIT=30
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=indoor-nav
# MINIO_PUBLIC_URL=http://localhost:9000
# S3_REGION=ap-southeast-1
# S3_BUCKET=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
# S3_PUBLIC_URL=

# mongo mặc định | opensearch provider-ready (fail-closed nếu chưa cấu hình)
SEARCH_PROVIDER=mongo
